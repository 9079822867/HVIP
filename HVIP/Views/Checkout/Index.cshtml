@model HVIP.Models.CheckoutViewModel
@{
    ViewBag.Title = "Checkout";
}

<!-- Breadcrumb -->
<div class="breadcrumb-bar">
    <div class="container">
        <span class="breadcrumb-list">
            <a href="@Url.Action("Index","Home")"><i class="fas fa-home"></i> Home</a>
            <span class="sep">/</span>
            <a href="@Url.Action("Index","Cart")">Cart</a>
            <span class="sep">/</span>
            <span>Checkout</span>
        </span>
    </div>
</div>

<section class="py-section">
    <div class="container">
        @using (Html.BeginForm("Index", "Checkout", FormMethod.Post))
        {
            @Html.AntiForgeryToken()
            <div class="row g-4">

                <!-- LEFT: Delivery Details -->
                <div class="col-lg-8">
                    <!-- Delivery Address -->
                    <div style="background:#fff;border-radius:12px;padding:24px;box-shadow:var(--shadow-sm);margin-bottom:20px;">
                        <h5 class="checkout-title"><i class="fas fa-map-marker-alt"></i>Delivery Address</h5>
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label">Full Name *</label>
                                @Html.TextBoxFor(m => m.FullName, new { @class = "form-control", placeholder = "Enter your full name" })
                                @Html.ValidationMessageFor(m => m.FullName, "", new { @class = "text-danger", style = "font-size:12px;" })
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Mobile Number *</label>
                                @Html.TextBoxFor(m => m.Phone, new { @class = "form-control", placeholder = "10-digit mobile number" })
                                @Html.ValidationMessageFor(m => m.Phone, "", new { @class = "text-danger", style = "font-size:12px;" })
                            </div>
                            <div class="col-12">
                                <label class="form-label">Email Address *</label>
                                @Html.TextBoxFor(m => m.Email, new { @class = "form-control", placeholder = "your@email.com", type = "email" })
                                @Html.ValidationMessageFor(m => m.Email, "", new { @class = "text-danger", style = "font-size:12px;" })
                            </div>
                            <div class="col-12">
                                <label class="form-label">Full Address *</label>
                                @Html.TextAreaFor(m => m.Address, new { @class = "form-control", rows = "2", placeholder = "House / Flat No., Street, Area, Landmark" })
                                @Html.ValidationMessageFor(m => m.Address, "", new { @class = "text-danger", style = "font-size:12px;" })
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">City *</label>
                                @Html.TextBoxFor(m => m.City, new { @class = "form-control", placeholder = "City" })
                                @Html.ValidationMessageFor(m => m.City, "", new { @class = "text-danger", style = "font-size:12px;" })
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">State *</label>
                                @Html.DropDownListFor(m => m.State,
                                    new SelectList(new[]{"Andhra Pradesh","Arunachal Pradesh","Assam","Bihar","Chhattisgarh","Goa","Gujarat","Haryana","Himachal Pradesh","Jharkhand","Karnataka","Kerala","Madhya Pradesh","Maharashtra","Manipur","Meghalaya","Mizoram","Nagaland","Odisha","Punjab","Rajasthan","Sikkim","Tamil Nadu","Telangana","Tripura","Uttar Pradesh","Uttarakhand","West Bengal","Delhi","Jammu & Kashmir","Ladakh","Puducherry","Chandigarh"}),
                                    "-- Select State --", new { @class = "form-control" })
                                @Html.ValidationMessageFor(m => m.State, "", new { @class = "text-danger", style = "font-size:12px;" })
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Pincode *</label>
                                @Html.TextBoxFor(m => m.Pincode, new { @class = "form-control", placeholder = "6-digit pincode", maxlength = "6" })
                                @Html.ValidationMessageFor(m => m.Pincode, "", new { @class = "text-danger", style = "font-size:12px;" })
                            </div>
                        </div>
                    </div>

                    <!-- Payment Method -->
                    <div style="background:#fff;border-radius:12px;padding:24px;box-shadow:var(--shadow-sm);">
                        <h5 class="checkout-title"><i class="fas fa-credit-card"></i>Payment Method</h5>
                        <div class="pay-option selected" id="payCOD" onclick="selectPay('COD')">
                            <i class="fas fa-money-bill-wave" style="color:var(--primary);font-size:22px;"></i>
                            <div>
                                <div style="font-weight:700;">Cash on Delivery (COD)</div>
                                <div style="font-size:12px;color:var(--text-muted);">Pay when you receive your order</div>
                            </div>
                            <i class="fas fa-check-circle ms-auto" style="color:var(--primary);" id="checkCOD"></i>
                        </div>
                        <div class="pay-option" id="payUPI" onclick="selectPay('UPI')">
                            <i class="fas fa-mobile-alt" style="color:#7b1fa2;font-size:22px;"></i>
                            <div>
                                <div style="font-weight:700;">UPI / GPay / PhonePe</div>
                                <div style="font-size:12px;color:var(--text-muted);">Pay instantly using UPI apps</div>
                            </div>
                            <i class="fas fa-check-circle ms-auto" style="color:var(--primary);display:none;" id="checkUPI"></i>
                        </div>
                        @Html.HiddenFor(m => m.PaymentMethod, new { id = "paymentMethod", Value = "COD" })
                    </div>
                </div>

                <!-- RIGHT: Order Summary -->
                <div class="col-lg-4">
                    <div class="cart-summary-card">
                        <h5 style="color:var(--primary-dark);font-weight:700;margin-bottom:16px;"><i class="fas fa-receipt me-2"></i>Order Summary</h5>

                        @if (Model.Cart != null)
                        {
                            foreach (var item in Model.Cart.Items)
                            {
                                <div class="order-item-row">
                                    <div class="order-item-icon" style="background:@item.CategoryColor;">
                                        <i class="@item.CategoryIcon"></i>
                                    </div>
                                    <div class="flex-grow-1">
                                        <div style="font-size:13.5px;font-weight:600;">@item.ProductName</div>
                                        <div style="font-size:12px;color:var(--text-muted);">Qty: @item.Quantity &nbsp;|&nbsp; @item.ProductSize</div>
                                    </div>
                                    <div style="font-weight:700;font-size:14px;white-space:nowrap;">&#8377;@item.Total.ToString("0")</div>
                                </div>
                            }
                            <div class="sum-row mt-2"><span>Subtotal</span><span>&#8377;@Model.Cart.SubTotal.ToString("0")</span></div>
                            <div class="sum-row">
                                <span>Shipping</span>
                                <span>@(Model.Cart.Shipping == 0 ? "FREE" : "&#8377;" + Model.Cart.Shipping.ToString("0"))</span>
                            </div>
                            <div class="sum-row total"><span>Total Payable</span><span>&#8377;@Model.Cart.GrandTotal.ToString("0")</span></div>
                        }

                        <button type="submit" class="btn-checkout" style="font-size:15px;">
                            <i class="fas fa-lock me-2"></i>Place Order
                        </button>
                        <div class="text-center mt-2" style="font-size:12px;color:var(--text-muted);">
                            <i class="fas fa-shield-alt text-success me-1"></i>100% Secure & Safe Checkout
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</section>

@section scripts {
@Scripts.Render("~/bundles/jqueryval")
<script>
    function selectPay(method) {
        document.getElementById('paymentMethod').value = method;
        ['COD','UPI'].forEach(function(m) {
            document.getElementById('pay'+m).classList.remove('selected');
            document.getElementById('check'+m).style.display = 'none';
        });
        document.getElementById('pay'+method).classList.add('selected');
        document.getElementById('check'+method).style.display = 'inline';
    }
</script>
}
