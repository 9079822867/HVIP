@model HVIP.Models.Order
@{
    ViewBag.Title = "Order Confirmed";
}

<section class="py-section" style="background:var(--light-bg);">
    <div class="container">
        <div class="success-card">
            <div class="success-icon">
                <i class="fas fa-check-circle"></i>
            </div>
            <h2 style="font-size:30px;font-weight:800;color:var(--primary-dark);margin-bottom:8px;">Order Confirmed!</h2>
            <p style="font-size:16px;color:var(--text-muted);margin-bottom:20px;">
                Thank you, <strong>@Model.CustomerName</strong>! Your order has been placed successfully.
            </p>

            <div class="order-num-box">
                <div style="font-size:12px;color:var(--text-muted);margin-bottom:4px;">ORDER NUMBER</div>
                <span>@Model.OrderNumber</span>
            </div>

            <div class="row g-3 mb-4 text-start" style="max-width:480px;margin:0 auto;">
                <div class="col-6">
                    <div style="font-size:12px;color:var(--text-muted);">Order Date</div>
                    <div style="font-weight:600;">@Model.OrderDate.ToString("dd MMM yyyy, hh:mm tt")</div>
                </div>
                <div class="col-6">
                    <div style="font-size:12px;color:var(--text-muted);">Payment</div>
                    <div style="font-weight:600;">@Model.PaymentMethod</div>
                </div>
                <div class="col-6">
                    <div style="font-size:12px;color:var(--text-muted);">Status</div>
                    <div><span class="badge-pill badge-best">@Model.Status</span></div>
                </div>
                <div class="col-6">
                    <div style="font-size:12px;color:var(--text-muted);">Total Amount</div>
                    <div style="font-weight:800;font-size:18px;color:var(--primary-dark);">₹@Model.GrandTotal.ToString("0")</div>
                </div>
            </div>

            <!-- Order Items -->
            <div style="background:var(--primary-xlight);border-radius:10px;padding:16px;margin-bottom:20px;text-align:left;">
                <div style="font-weight:700;color:var(--primary-dark);margin-bottom:12px;font-size:14px;">ORDERED ITEMS</div>
                @foreach (var item in Model.Items)
                {
                    <div class="order-item-row" style="border-color:#c8e6c9;">
                        <div class="order-item-icon" style="background:@item.CategoryColor;">
                            <i class="@item.CategoryIcon"></i>
                        </div>
                        <div class="flex-grow-1">
                            <div style="font-size:13.5px;font-weight:600;">@item.ProductName</div>
                            <div style="font-size:12px;color:var(--text-muted);">Qty: @item.Quantity &nbsp;|&nbsp; @item.ProductSize</div>
                        </div>
                        <div style="font-weight:700;font-size:14px;">₹@item.Total.ToString("0")</div>
                    </div>
                }
            </div>

            <!-- Delivery Address -->
            <div style="background:#f8f9fa;border-radius:10px;padding:14px 16px;margin-bottom:22px;text-align:left;font-size:13.5px;">
                <strong><i class="fas fa-map-marker-alt me-2" style="color:var(--primary);"></i>Delivery To:</strong>
                <div style="margin-top:4px;color:var(--text-muted);">
                    @Model.CustomerName &bull; @Model.Phone<br/>
                    @Model.Address, @Model.City, @Model.State — @Model.Pincode
                </div>
            </div>

            <p style="font-size:13.5px;color:var(--text-muted);margin-bottom:20px;">
                <i class="fas fa-envelope me-1"></i>A confirmation has been sent to <strong>@Model.Email</strong><br>
                <i class="fas fa-clock me-1"></i>Estimated delivery: <strong>3–5 business days</strong>
            </p>

            <div class="d-flex justify-content-center gap-3 flex-wrap">
                <a href="@Url.Action("Index","Shop")" class="btn-continue">
                    <i class="fas fa-shopping-bag me-2"></i>Continue Shopping
                </a>
                <a href="@Url.Action("Index","Home")" class="btn-continue" style="background:var(--text-muted);">
                    <i class="fas fa-home me-2"></i>Go Home
                </a>
            </div>
        </div>
    </div>
</section>
