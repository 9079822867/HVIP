@model HVIP.Models.User
@using HVIP.Models
@{
    ViewBag.Title = "My Profile";
    var orders = ViewBag.UserOrders as List<OrderSummary> ?? new List<OrderSummary>();
}

<!-- Hero -->
<div style="background:linear-gradient(135deg,#0d4a1e,#1a6e2e);padding:50px 0;color:#fff;text-align:center;">
    <div class="container">
        <div class="profile-avatar-lg">
            @{ var initials = string.IsNullOrEmpty(Model.Name) ? "U" : Model.Name.Substring(0,1).ToUpper(); }
            @initials
        </div>
        <h2 style="margin:10px 0 4px;font-weight:800;">@Model.Name</h2>
        <p style="opacity:.8;font-size:14px;"><i class="fas fa-envelope me-1"></i>@Model.Email</p>
        <p style="opacity:.7;font-size:12px;">Member since @Model.RegisteredOn.ToString("MMMM yyyy")</p>

        <!-- Quick stats -->
        <div class="d-flex justify-content-center gap-4 mt-3">
            <div style="text-align:center;">
                <div style="font-size:24px;font-weight:800;">@orders.Count</div>
                <div style="font-size:12px;opacity:.75;">Orders</div>
            </div>
            <div style="width:1px;background:rgba(255,255,255,.3);"></div>
            <div style="text-align:center;">
                <div style="font-size:24px;font-weight:800;">
                    @(orders.Count(o => o.Status == "Delivered"))
                </div>
                <div style="font-size:12px;opacity:.75;">Delivered</div>
            </div>
        </div>
    </div>
</div>

<section class="py-section bg-light-green">
    <div class="container">
        <div class="row justify-content-center g-4">

            <!-- Profile Form -->
            <div class="col-lg-7">
                <div class="auth-card" style="border-radius:16px;">
                    <h4 style="color:var(--primary-dark);margin-bottom:20px;font-weight:700;">
                        <i class="fas fa-user-edit me-2"></i>Edit Profile
                    </h4>

                    @if (TempData["ProfileSaved"] != null)
                    {
                        <div class="auth-alert" style="background:#e8f5e9;border:1px solid var(--primary-light);color:#1b5e20;border-radius:10px;padding:12px 16px;margin-bottom:16px;">
                            <i class="fas fa-check-circle me-1"></i>@TempData["ProfileSaved"]
                        </div>
                    }

                    @using (Html.BeginForm("Profile", "Account", FormMethod.Post))
                    {
                        @Html.AntiForgeryToken()
                        @Html.HiddenFor(m => m.Id)
                        @Html.HiddenFor(m => m.Email)
                        @Html.HiddenFor(m => m.RegisteredOn)
                        @Html.HiddenFor(m => m.PasswordHash)

                        <div class="row g-3">
                            <div class="col-md-6">
                                <div class="auth-form-group">
                                    <label><i class="fas fa-user me-1"></i>Full Name</label>
                                    @Html.TextBoxFor(m => m.Name, new { @class = "auth-input" })
                                    @Html.ValidationMessageFor(m => m.Name, "", new { @class = "auth-error" })
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="auth-form-group">
                                    <label><i class="fas fa-phone me-1"></i>Mobile Number</label>
                                    @Html.TextBoxFor(m => m.Phone, new { @class = "auth-input" })
                                    @Html.ValidationMessageFor(m => m.Phone, "", new { @class = "auth-error" })
                                </div>
                            </div>
                            <div class="col-12">
                                <div class="auth-form-group">
                                    <label><i class="fas fa-home me-1"></i>Address</label>
                                    @Html.TextBoxFor(m => m.Address, new { @class = "auth-input", placeholder = "House No., Street, Area" })
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="auth-form-group">
                                    <label><i class="fas fa-city me-1"></i>City</label>
                                    @Html.TextBoxFor(m => m.City, new { @class = "auth-input", placeholder = "City" })
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="auth-form-group">
                                    <label><i class="fas fa-map me-1"></i>State</label>
                                    @Html.DropDownListFor(m => m.State,
                                        new SelectList(new[]{"Andhra Pradesh","Arunachal Pradesh","Assam","Bihar","Chhattisgarh",
                                            "Goa","Gujarat","Haryana","Himachal Pradesh","Jharkhand","Karnataka","Kerala",
                                            "Madhya Pradesh","Maharashtra","Manipur","Meghalaya","Mizoram","Nagaland",
                                            "Odisha","Punjab","Rajasthan","Sikkim","Tamil Nadu","Telangana","Tripura",
                                            "Uttar Pradesh","Uttarakhand","West Bengal","Delhi","Jammu & Kashmir","Ladakh"}),
                                        "-- Select State --", new { @class = "auth-input" })
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="auth-form-group">
                                    <label><i class="fas fa-map-pin me-1"></i>Pincode</label>
                                    @Html.TextBoxFor(m => m.Pincode, new { @class = "auth-input", placeholder = "6-digit PIN" })
                                </div>
                            </div>
                        </div>

                        <div class="d-flex gap-3 mt-3 flex-wrap">
                            <button type="submit" class="auth-btn" style="max-width:200px;">
                                <i class="fas fa-save me-2"></i>Save Changes
                            </button>
                        </div>
                    }
                </div>
            </div>

            <!-- Account Info & Actions -->
            <div class="col-lg-3">
                <!-- Account Details -->
                <div class="auth-card mb-3" style="border-radius:16px;padding:20px;">
                    <h6 style="color:var(--primary-dark);font-weight:700;margin-bottom:14px;">
                        <i class="fas fa-id-card me-2"></i>Account Details
                    </h6>
                    <div style="font-size:13px;color:var(--text-muted);line-height:2;">
                        <div><strong>Email:</strong><br>@Model.Email</div>
                        <div style="margin-top:8px;"><strong>Member Since:</strong><br>@Model.RegisteredOn.ToString("dd MMM yyyy")</div>
                    </div>
                </div>

                <!-- Quick Links -->
                <div class="auth-card" style="border-radius:16px;padding:20px;">
                    <h6 style="color:var(--primary-dark);font-weight:700;margin-bottom:14px;">
                        <i class="fas fa-link me-2"></i>Quick Links
                    </h6>
                    <div class="d-flex flex-column" style="gap:8px;">
                        <a href="@Url.Action("Orders","Account")" class="profile-quick-link">
                            <i class="fas fa-shopping-bag me-2"></i>My Orders
                            @if (orders.Count > 0)
                            { <span class="badge-pill" style="background:#e8f5e9;color:#1a6e2e;font-size:11px;padding:2px 8px;border-radius:20px;margin-left:auto;">@orders.Count</span> }
                        </a>
                        <a href="@Url.Action("ChangePassword","Account")" class="profile-quick-link">
                            <i class="fas fa-key me-2"></i>Change Password
                        </a>
                        <a href="@Url.Action("Index","Shop")" class="profile-quick-link">
                            <i class="fas fa-store me-2"></i>Shop Now
                        </a>
                        <a href="@Url.Action("Index","Cart")" class="profile-quick-link">
                            <i class="fas fa-cart-shopping me-2"></i>My Cart
                        </a>
                        <a href="@Url.Action("Contact","Home")" class="profile-quick-link">
                            <i class="fas fa-headset me-2"></i>Support
                        </a>
                        <div style="margin-top:6px;">
                            @using (Html.BeginForm("Logout", "Account", FormMethod.Post))
                            {
                                @Html.AntiForgeryToken()
                                <button type="submit" class="profile-quick-link profile-logout-btn" style="width:100%;border:none;cursor:pointer;">
                                    <i class="fas fa-sign-out-alt me-2"></i>Sign Out
                                </button>
                            }
                        </div>
                    </div>
                </div>

                <!-- Recent Order Peek -->
                @if (orders.Count > 0)
                {
                    var last = orders[0];
                    <div class="auth-card mt-3" style="border-radius:16px;padding:20px;">
                        <h6 style="color:var(--primary-dark);font-weight:700;margin-bottom:12px;">
                            <i class="fas fa-clock me-2"></i>Latest Order
                        </h6>
                        <div style="font-size:13px;">
                            <div style="font-weight:600;">@last.OrderNumber</div>
                            <div style="color:var(--text-muted);font-size:12px;">@last.OrderDate.ToString("dd MMM yyyy")</div>
                            <div class="d-flex justify-content-between align-items-center mt-2">
                                <span style="font-weight:700;color:var(--primary-dark);">&#8377;@last.GrandTotal.ToString("N0")</span>
                                <span class="badge-pill" style="background:@(last.Status=="Delivered"?"#e8f5e9":last.Status=="Shipped"?"#e3f2fd":"#fff3e0");color:@(last.Status=="Delivered"?"#1a6e2e":last.Status=="Shipped"?"#0277bd":"#e65100");font-size:11px;padding:3px 10px;border-radius:20px;">@last.Status</span>
                            </div>
                        </div>
                        <a href="@Url.Action("Orders","Account")" style="display:block;text-align:center;font-size:12px;color:var(--primary);margin-top:10px;">
                            View all orders →
                        </a>
                    </div>
                }
            </div>

        </div>
    </div>
</section>

@section scripts {
@Scripts.Render("~/bundles/jqueryval")
}
