@model HVIP.Models.ChangePasswordViewModel
@{
    ViewBag.Title = "Change Password";
}

<!-- Breadcrumb -->
<div class="breadcrumb-bar">
    <div class="container">
        <span class="breadcrumb-list">
            <a href="@Url.Action("Index","Home")"><i class="fas fa-home"></i> Home</a>
            <span class="sep">/</span>
            <a href="@Url.Action("Profile","Account")">My Account</a>
            <span class="sep">/</span>
            <span>Change Password</span>
        </span>
    </div>
</div>

<!-- Hero -->
<div style="background:linear-gradient(135deg,#0d4a1e,#1a6e2e);padding:40px 0;color:#fff;text-align:center;">
    <div class="container">
        <div style="width:64px;height:64px;background:rgba(255,255,255,.15);border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 12px;font-size:24px;">
            <i class="fas fa-key"></i>
        </div>
        <h2 style="font-weight:800;margin:0 0 4px;">Change Password</h2>
        <p style="opacity:.8;font-size:14px;margin:0;">Keep your account secure with a strong password</p>
    </div>
</div>

<section class="py-section bg-light-green">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-5 col-md-7">
                <div class="auth-card" style="border-radius:16px;">

                    @if (!ViewData.ModelState.IsValid && ViewData.ModelState.ContainsKey(""))
                    {
                        <div class="auth-alert mb-3" style="background:#ffebee;border:1px solid #ffcdd2;color:#c62828;border-radius:10px;padding:12px 16px;">
                            <i class="fas fa-exclamation-circle me-1"></i>@Html.ValidationSummary(true)
                        </div>
                    }

                    @using (Html.BeginForm("ChangePassword", "Account", FormMethod.Post))
                    {
                        @Html.AntiForgeryToken()

                        <div class="auth-form-group">
                            <label><i class="fas fa-lock me-1"></i>Current Password</label>
                            @Html.PasswordFor(m => m.CurrentPassword, new { @class="auth-input", placeholder="Enter your current password" })
                            @Html.ValidationMessageFor(m => m.CurrentPassword, "", new { @class="auth-error", style="color:#c62828;font-size:12px;" })
                        </div>

                        <div class="auth-form-group">
                            <label><i class="fas fa-key me-1"></i>New Password</label>
                            @Html.PasswordFor(m => m.NewPassword, new { @class="auth-input", id="newPass", placeholder="Minimum 6 characters" })
                            @Html.ValidationMessageFor(m => m.NewPassword, "", new { @class="auth-error", style="color:#c62828;font-size:12px;" })
                            <!-- Strength bar -->
                            <div id="strength-bar" style="height:4px;border-radius:2px;margin-top:6px;background:#e0e0e0;overflow:hidden;">
                                <div id="strength-fill" style="height:100%;width:0%;transition:.3s;background:#4caf50;"></div>
                            </div>
                            <div id="strength-label" style="font-size:11px;color:var(--text-muted);margin-top:3px;"></div>
                        </div>

                        <div class="auth-form-group">
                            <label><i class="fas fa-check-double me-1"></i>Confirm New Password</label>
                            @Html.PasswordFor(m => m.ConfirmPassword, new { @class="auth-input", id="confirmPass", placeholder="Repeat new password" })
                            @Html.ValidationMessageFor(m => m.ConfirmPassword, "", new { @class="auth-error", style="color:#c62828;font-size:12px;" })
                            <div id="match-msg" style="font-size:12px;margin-top:4px;"></div>
                        </div>

                        <button type="submit" class="auth-btn mt-2">
                            <i class="fas fa-save me-2"></i>Update Password
                        </button>

                        <div class="text-center mt-3">
                            <a href="@Url.Action("Profile","Account")" style="font-size:13px;color:var(--text-muted);">
                                <i class="fas fa-arrow-left me-1"></i>Back to Profile
                            </a>
                        </div>
                    }
                </div>

                <!-- Tips -->
                <div class="auth-card mt-3" style="border-radius:14px;padding:18px;background:#f8fdf8;border:1px solid #c8e6c9;">
                    <h6 style="color:var(--primary-dark);font-weight:700;margin-bottom:10px;font-size:13px;">
                        <i class="fas fa-shield-alt me-2"></i>Password Tips
                    </h6>
                    <ul style="font-size:12.5px;color:#555;padding-left:18px;margin:0;line-height:2;">
                        <li>At least <strong>6 characters</strong> long</li>
                        <li>Mix letters, <strong>numbers</strong> and symbols</li>
                        <li>Don't reuse old passwords</li>
                        <li>Never share your password</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</section>

@section scripts {
@Scripts.Render("~/bundles/jqueryval")
<script>
    // Password strength indicator
    document.getElementById('newPass').addEventListener('input', function () {
        var v = this.value, score = 0;
        if (v.length >= 6)  score++;
        if (v.length >= 10) score++;
        if (/[A-Z]/.test(v)) score++;
        if (/[0-9]/.test(v)) score++;
        if (/[^A-Za-z0-9]/.test(v)) score++;

        var labels = ['','Weak','Fair','Good','Strong','Very Strong'];
        var colors = ['','#f44336','#ff9800','#2196f3','#4caf50','#1b5e20'];
        var pct    = [0, 20, 40, 65, 85, 100];

        document.getElementById('strength-fill').style.width  = pct[score] + '%';
        document.getElementById('strength-fill').style.background = colors[score] || '#e0e0e0';
        document.getElementById('strength-label').textContent = labels[score] || '';
        document.getElementById('strength-label').style.color = colors[score] || '';
    });

    // Password match check
    document.getElementById('confirmPass').addEventListener('input', function () {
        var match = this.value === document.getElementById('newPass').value;
        var el = document.getElementById('match-msg');
        el.textContent  = this.value ? (match ? '✓ Passwords match' : '✗ Passwords do not match') : '';
        el.style.color  = match ? '#1a6e2e' : '#c62828';
    });
</script>
}
