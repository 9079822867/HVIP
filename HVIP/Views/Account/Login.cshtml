@model HVIP.Models.LoginViewModel
@{
    ViewBag.Title = "Login";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="login-page-wrap">
    <div class="login-split-card">

        <!-- LEFT PANEL — Brand -->
        <div class="login-brand-panel">
            <div class="login-brand-inner">
                <div class="login-brand-logo">
                    <i class="fas fa-leaf"></i>
                </div>
                <h1 class="login-brand-title">HVIP</h1>
                <p class="login-brand-sub">HOMEOPATHIC</p>
                <p class="login-brand-tagline">Natural healing, trusted since 1984</p>

                <div class="login-brand-features">
                    <div class="login-feature-item">
                        <div class="login-feature-icon"><i class="fas fa-shield-alt"></i></div>
                        <div>
                            <div class="login-feature-title">100% Secure</div>
                            <div class="login-feature-desc">Your data is safe with us</div>
                        </div>
                    </div>
                    <div class="login-feature-item">
                        <div class="login-feature-icon"><i class="fas fa-truck"></i></div>
                        <div>
                            <div class="login-feature-title">Fast Delivery</div>
                            <div class="login-feature-desc">Free shipping above ₹500</div>
                        </div>
                    </div>
                    <div class="login-feature-item">
                        <div class="login-feature-icon"><i class="fas fa-star"></i></div>
                        <div>
                            <div class="login-feature-title">10 Lakh+ Customers</div>
                            <div class="login-feature-desc">Trusted across India</div>
                        </div>
                    </div>
                    <div class="login-feature-item">
                        <div class="login-feature-icon"><i class="fas fa-certificate"></i></div>
                        <div>
                            <div class="login-feature-title">GMP Certified</div>
                            <div class="login-feature-desc">ISO 9001:2015 compliant</div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Decorative circles -->
            <div class="login-deco login-deco-1"></div>
            <div class="login-deco login-deco-2"></div>
            <div class="login-deco login-deco-3"></div>
        </div>

        <!-- RIGHT PANEL — Form -->
        <div class="login-form-panel">
            <div class="login-form-inner">

                <!-- Top nav link -->
                <div class="login-top-nav">
                    <a href="@Url.Action("Index","Home")">
                        <i class="fas fa-arrow-left me-1"></i> Back to Home
                    </a>
                </div>

                <h2 class="login-form-title">Welcome Back! <span>👋</span></h2>
                <p class="login-form-sub">Sign in to your HVIP account to continue</p>

                <!-- Demo credentials box -->
                <div class="login-demo-box">
                    <div class="login-demo-icon"><i class="fas fa-lightbulb"></i></div>
                    <div>
                        <div style="font-weight:700;font-size:13px;color:#1b5e20;">Try Demo Account</div>
                        <div style="font-size:12.5px;color:#2e7d32;">
                            <i class="fas fa-envelope" style="width:14px;"></i> demo@hvip.com &nbsp;
                            <i class="fas fa-key" style="width:14px;"></i> Demo@123
                        </div>
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(ViewBag.Error as string))
                {
                    <div class="lf-alert lf-alert-danger">
                        <i class="fas fa-exclamation-circle me-2"></i>@ViewBag.Error
                    </div>
                }

                @using (Html.BeginForm("Login", "Account", new { ReturnUrl = Model.ReturnUrl }, FormMethod.Post))
                {
                    @Html.AntiForgeryToken()
                    @Html.HiddenFor(m => m.ReturnUrl)

                    <!-- Email Field -->
                    <div class="lf-group">
                        <label class="lf-label">Email Address</label>
                        <div class="lf-input-wrap">
                            <span class="lf-icon"><i class="fas fa-envelope"></i></span>
                            @Html.TextBoxFor(m => m.Email, new {
                                @class = "lf-input",
                                placeholder = "your@email.com",
                                type = "email",
                                autocomplete = "email"
                            })
                        </div>
                        @Html.ValidationMessageFor(m => m.Email, "", new { @class = "lf-error" })
                    </div>

                    <!-- Password Field -->
                    <div class="lf-group">
                        <label class="lf-label">Password</label>
                        <div class="lf-input-wrap">
                            <span class="lf-icon"><i class="fas fa-lock"></i></span>
                            @Html.PasswordFor(m => m.Password, new {
                                @class = "lf-input lf-input-pwd",
                                placeholder = "Enter your password",
                                id = "loginPwd",
                                autocomplete = "current-password"
                            })
                            <button type="button" class="lf-eye-btn" onclick="togglePwd('loginPwd',this)" tabindex="-1">
                                <i class="fas fa-eye"></i>
                            </button>
                        </div>
                        @Html.ValidationMessageFor(m => m.Password, "", new { @class = "lf-error" })
                    </div>

                    @Html.ValidationSummary(true, "", new { @class = "lf-alert lf-alert-danger" })

                    <!-- Submit -->
                    <button type="submit" class="lf-btn-submit">
                        <i class="fas fa-sign-in-alt me-2"></i> Sign In to HVIP
                    </button>
                }

                <!-- Divider -->
                <div class="lf-divider"><span>New to HVIP?</span></div>

                <!-- Register link -->
                <a href="@Url.Action("Register","Account")" class="lf-btn-register">
                    <i class="fas fa-user-plus me-2"></i> Create Free Account
                </a>

            </div>
        </div>

    </div>
</div>

@section scripts {
@Scripts.Render("~/bundles/jqueryval")
<script>
    function togglePwd(id, btn) {
        var el = document.getElementById(id);
        if (el.type === 'password') {
            el.type = 'text';
            btn.innerHTML = '<i class="fas fa-eye-slash"></i>';
        } else {
            el.type = 'password';
            btn.innerHTML = '<i class="fas fa-eye"></i>';
        }
    }
</script>
}
