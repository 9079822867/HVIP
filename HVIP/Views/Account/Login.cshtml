@model HVIP.Models.LoginViewModel
@{
    ViewBag.Title = "Login";
}

<section class="py-section" style="background:var(--light-bg);min-height:70vh;display:flex;align-items:center;">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-8 col-lg-5">
                <div class="auth-card">
                    <!-- Header -->
                    <div class="auth-card-header">
                        <div class="auth-avatar"><i class="fas fa-user-circle"></i></div>
                        <h2>Welcome Back!</h2>
                        <p>Sign in to your HVIP account</p>
                    </div>

                    <!-- Demo hint -->
                    <div class="auth-demo-hint">
                        <i class="fas fa-info-circle me-1"></i>
                        <strong>Demo:</strong> demo@hvip.com &nbsp;/&nbsp; Demo@123
                    </div>

                    @if (!string.IsNullOrEmpty(ViewBag.Error as string))
                    {
                        <div class="auth-alert auth-alert-danger">
                            <i class="fas fa-exclamation-circle me-1"></i>@ViewBag.Error
                        </div>
                    }

                    @using (Html.BeginForm("Login", "Account", new { ReturnUrl = Model.ReturnUrl }, FormMethod.Post))
                    {
                        @Html.AntiForgeryToken()
                        @Html.HiddenFor(m => m.ReturnUrl)

                        <div class="auth-form-group">
                            <label><i class="fas fa-envelope me-1"></i>Email Address</label>
                            @Html.TextBoxFor(m => m.Email, new { @class = "auth-input", placeholder = "your@email.com", type = "email", autocomplete = "email" })
                            @Html.ValidationMessageFor(m => m.Email, "", new { @class = "auth-error" })
                        </div>

                        <div class="auth-form-group">
                            <label><i class="fas fa-lock me-1"></i>Password</label>
                            <div class="auth-input-wrap">
                                @Html.PasswordFor(m => m.Password, new { @class = "auth-input", placeholder = "Enter password", id = "loginPassword", autocomplete = "current-password" })
                                <button type="button" class="pwd-toggle" onclick="togglePwd('loginPassword', this)">
                                    <i class="fas fa-eye"></i>
                                </button>
                            </div>
                            @Html.ValidationMessageFor(m => m.Password, "", new { @class = "auth-error" })
                        </div>

                        @Html.ValidationSummary(true, "", new { @class = "auth-alert auth-alert-danger" })

                        <button type="submit" class="auth-btn">
                            <i class="fas fa-sign-in-alt me-2"></i>Sign In
                        </button>
                    }

                    <div class="auth-footer">
                        Don't have an account?
                        <a href="@Url.Action("Register","Account")">Create one free</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@section scripts {
@Scripts.Render("~/bundles/jqueryval")
<script>
    function togglePwd(id, btn) {
        var el = document.getElementById(id);
        if (el.type === 'password') {
            el.type = 'text';
            btn.innerHTML = '<i class="fas fa-eye-slash"></i>';
        } else {
            el.type = 'password';
            btn.innerHTML = '<i class="fas fa-eye"></i>';
        }
    }
</script>
}
