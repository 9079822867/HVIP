@model HVIP.Models.RegisterViewModel
@{
    ViewBag.Title = "Create Account";
}

<section class="py-section" style="background:var(--light-bg);min-height:70vh;display:flex;align-items:center;">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-8 col-lg-6">
                <div class="auth-card">
                    <!-- Header -->
                    <div class="auth-card-header">
                        <div class="auth-avatar" style="background:linear-gradient(135deg,#1a6e2e,#2e8b47);">
                            <i class="fas fa-user-plus"></i>
                        </div>
                        <h2>Create Account</h2>
                        <p>Join HVIP and start your wellness journey</p>
                    </div>

                    @using (Html.BeginForm("Register", "Account", FormMethod.Post))
                    {
                        @Html.AntiForgeryToken()

                        <div class="row g-3">
                            <div class="col-12">
                                <div class="auth-form-group">
                                    <label><i class="fas fa-user me-1"></i>Full Name</label>
                                    @Html.TextBoxFor(m => m.Name, new { @class = "auth-input", placeholder = "Your full name", autocomplete = "name" })
                                    @Html.ValidationMessageFor(m => m.Name, "", new { @class = "auth-error" })
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="auth-form-group">
                                    <label><i class="fas fa-envelope me-1"></i>Email Address</label>
                                    @Html.TextBoxFor(m => m.Email, new { @class = "auth-input", placeholder = "your@email.com", type = "email", autocomplete = "email" })
                                    @Html.ValidationMessageFor(m => m.Email, "", new { @class = "auth-error" })
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="auth-form-group">
                                    <label><i class="fas fa-phone me-1"></i>Mobile Number</label>
                                    @Html.TextBoxFor(m => m.Phone, new { @class = "auth-input", placeholder = "10-digit mobile", type = "tel", autocomplete = "tel" })
                                    @Html.ValidationMessageFor(m => m.Phone, "", new { @class = "auth-error" })
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="auth-form-group">
                                    <label><i class="fas fa-lock me-1"></i>Password</label>
                                    <div class="auth-input-wrap">
                                        @Html.PasswordFor(m => m.Password, new { @class = "auth-input", placeholder = "Min. 6 characters", id = "regPassword", autocomplete = "new-password" })
                                        <button type="button" class="pwd-toggle" onclick="togglePwd('regPassword', this)">
                                            <i class="fas fa-eye"></i>
                                        </button>
                                    </div>
                                    @Html.ValidationMessageFor(m => m.Password, "", new { @class = "auth-error" })
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="auth-form-group">
                                    <label><i class="fas fa-lock me-1"></i>Confirm Password</label>
                                    <div class="auth-input-wrap">
                                        @Html.PasswordFor(m => m.ConfirmPassword, new { @class = "auth-input", placeholder = "Re-enter password", id = "regConfirm", autocomplete = "new-password" })
                                        <button type="button" class="pwd-toggle" onclick="togglePwd('regConfirm', this)">
                                            <i class="fas fa-eye"></i>
                                        </button>
                                    </div>
                                    @Html.ValidationMessageFor(m => m.ConfirmPassword, "", new { @class = "auth-error" })
                                </div>
                            </div>
                        </div>

                        @Html.ValidationSummary(true, "", new { @class = "auth-alert auth-alert-danger mt-3" })

                        <button type="submit" class="auth-btn mt-3">
                            <i class="fas fa-user-plus me-2"></i>Create My Account
                        </button>
                    }

                    <div class="auth-footer">
                        Already have an account?
                        <a href="@Url.Action("Login","Account")">Sign in here</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@section scripts {
@Scripts.Render("~/bundles/jqueryval")
<script>
    function togglePwd(id, btn) {
        var el = document.getElementById(id);
        if (el.type === 'password') {
            el.type = 'text';
            btn.innerHTML = '<i class="fas fa-eye-slash"></i>';
        } else {
            el.type = 'password';
            btn.innerHTML = '<i class="fas fa-eye"></i>';
        }
    }
</script>
}
