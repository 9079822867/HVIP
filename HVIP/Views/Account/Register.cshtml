@model HVIP.Models.RegisterViewModel
@{
    ViewBag.Title = "Create Account";
}

<div class="login-page-wrap">
    <div class="login-split-card" style="max-width:1040px;">

        <!-- LEFT PANEL — Brand -->
        <div class="login-brand-panel">
            <div class="login-brand-inner">
                <div class="login-brand-logo">
                    <i class="fas fa-user-plus"></i>
                </div>
                <h1 class="login-brand-title">JOIN US</h1>
                <p class="login-brand-sub">HVIP HOMEOPATHIC</p>
                <p class="login-brand-tagline">Start your natural healing journey today</p>

                <div class="login-brand-features">
                    <div class="login-feature-item">
                        <div class="login-feature-icon"><i class="fas fa-gift"></i></div>
                        <div>
                            <div class="login-feature-title">Welcome Offer</div>
                            <div class="login-feature-desc">Use code HVIP15 for 15% off</div>
                        </div>
                    </div>
                    <div class="login-feature-item">
                        <div class="login-feature-icon"><i class="fas fa-history"></i></div>
                        <div>
                            <div class="login-feature-title">Order History</div>
                            <div class="login-feature-desc">Track all your past orders</div>
                        </div>
                    </div>
                    <div class="login-feature-item">
                        <div class="login-feature-icon"><i class="fas fa-bell"></i></div>
                        <div>
                            <div class="login-feature-title">Exclusive Offers</div>
                            <div class="login-feature-desc">Members-only deals & discounts</div>
                        </div>
                    </div>
                    <div class="login-feature-item">
                        <div class="login-feature-icon"><i class="fas fa-headset"></i></div>
                        <div>
                            <div class="login-feature-title">Priority Support</div>
                            <div class="login-feature-desc">Dedicated help for members</div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="login-deco login-deco-1"></div>
            <div class="login-deco login-deco-2"></div>
            <div class="login-deco login-deco-3"></div>
        </div>

        <!-- RIGHT PANEL — Form -->
        <div class="login-form-panel" style="padding:36px 44px;">
            <div class="login-form-inner" style="max-width:440px;">

                <div class="login-top-nav">
                    <a href="@Url.Action("Login","Account")">
                        <i class="fas fa-arrow-left me-1"></i> Already have an account? Sign in
                    </a>
                </div>

                <h2 class="login-form-title">Create Account <span>🌿</span></h2>
                <p class="login-form-sub">Fill in the details below — takes less than a minute!</p>

                @using (Html.BeginForm("Register", "Account", FormMethod.Post))
                {
                    @Html.AntiForgeryToken()

                    <div class="row g-3">
                        <div class="col-12">
                            <div class="lf-group" style="margin-bottom:0;">
                                <label class="lf-label">Full Name</label>
                                <div class="lf-input-wrap">
                                    <span class="lf-icon"><i class="fas fa-user"></i></span>
                                    @Html.TextBoxFor(m => m.Name, new { @class = "lf-input", placeholder = "Your full name", autocomplete = "name" })
                                </div>
                                @Html.ValidationMessageFor(m => m.Name, "", new { @class = "lf-error" })
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="lf-group" style="margin-bottom:0;">
                                <label class="lf-label">Email Address</label>
                                <div class="lf-input-wrap">
                                    <span class="lf-icon"><i class="fas fa-envelope"></i></span>
                                    @Html.TextBoxFor(m => m.Email, new { @class = "lf-input", placeholder = "your@email.com", type = "email", autocomplete = "email" })
                                </div>
                                @Html.ValidationMessageFor(m => m.Email, "", new { @class = "lf-error" })
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="lf-group" style="margin-bottom:0;">
                                <label class="lf-label">Mobile Number</label>
                                <div class="lf-input-wrap">
                                    <span class="lf-icon"><i class="fas fa-phone"></i></span>
                                    @Html.TextBoxFor(m => m.Phone, new { @class = "lf-input", placeholder = "10-digit mobile", type = "tel", autocomplete = "tel" })
                                </div>
                                @Html.ValidationMessageFor(m => m.Phone, "", new { @class = "lf-error" })
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="lf-group" style="margin-bottom:0;">
                                <label class="lf-label">Password</label>
                                <div class="lf-input-wrap">
                                    <span class="lf-icon"><i class="fas fa-lock"></i></span>
                                    @Html.PasswordFor(m => m.Password, new { @class = "lf-input lf-input-pwd", placeholder = "Min. 6 characters", id = "regPwd", autocomplete = "new-password" })
                                    <button type="button" class="lf-eye-btn" onclick="togglePwd('regPwd',this)" tabindex="-1">
                                        <i class="fas fa-eye"></i>
                                    </button>
                                </div>
                                @Html.ValidationMessageFor(m => m.Password, "", new { @class = "lf-error" })
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="lf-group" style="margin-bottom:0;">
                                <label class="lf-label">Confirm Password</label>
                                <div class="lf-input-wrap">
                                    <span class="lf-icon"><i class="fas fa-lock"></i></span>
                                    @Html.PasswordFor(m => m.ConfirmPassword, new { @class = "lf-input lf-input-pwd", placeholder = "Re-enter password", id = "regConfirm", autocomplete = "new-password" })
                                    <button type="button" class="lf-eye-btn" onclick="togglePwd('regConfirm',this)" tabindex="-1">
                                        <i class="fas fa-eye"></i>
                                    </button>
                                </div>
                                @Html.ValidationMessageFor(m => m.ConfirmPassword, "", new { @class = "lf-error" })
                            </div>
                        </div>
                    </div>

                    @Html.ValidationSummary(true, "", new { @class = "lf-alert lf-alert-danger mt-3" })

                    <button type="submit" class="lf-btn-submit mt-3">
                        <i class="fas fa-user-plus me-2"></i> Create My Account
                    </button>
                }

                <div class="lf-divider mt-3">or</div>

                <a href="@Url.Action("Login","Account")" class="lf-btn-register">
                    <i class="fas fa-sign-in-alt me-2"></i> Sign In Instead
                </a>

            </div>
        </div>

    </div>
</div>

@section scripts {
@Scripts.Render("~/bundles/jqueryval")
<script>
    function togglePwd(id, btn) {
        var el = document.getElementById(id);
        if (el.type === 'password') {
            el.type = 'text';
            btn.innerHTML = '<i class="fas fa-eye-slash"></i>';
        } else {
            el.type = 'password';
            btn.innerHTML = '<i class="fas fa-eye"></i>';
        }
    }
</script>
}
