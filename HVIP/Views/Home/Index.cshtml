@using HVIP.Models
@{
    ViewBag.Title = "Home";
    var featured  = ViewBag.FeaturedProducts as List<Product> ?? new List<Product>();
    var bestsellers = ViewBag.BestSellers as List<Product> ?? new List<Product>();
    var categories  = ViewBag.Categories  as List<Category> ?? new List<Category>();
}

<!-- ═══ HERO CAROUSEL ═══════════════════════════════════════════════ -->
<section class="hero-section">
    <!-- Slide 1 -->
    <div class="hero-slide slide-1 active">
        <div class="hero-icon-bg"><i class="fas fa-leaf"></i></div>
        <div class="container">
            <div class="hero-content">
                <span class="hero-tag">🌿 Trusted Since 1984</span>
                <h1 class="hero-title">India's Most Trusted<br><span>Homeopathic Medicines</span></h1>
                <p class="hero-desc">100% authentic, GMP certified homeopathic remedies prepared with scientific precision for natural healing.</p>
                <div class="hero-actions">
                    <a href="@Url.Action("Index","Shop")" class="btn-hero-primary">Shop Now</a>
                    <a href="@Url.Action("About","Home")" class="btn-hero-outline">Learn More</a>
                </div>
                <div class="hero-stats">
                    <div class="hero-stat-item"><div class="hero-stat-num">10L+</div><div class="hero-stat-label">Happy Customers</div></div>
                    <div class="hero-stat-item"><div class="hero-stat-num">31+</div><div class="hero-stat-label">Products</div></div>
                    <div class="hero-stat-item"><div class="hero-stat-num">40+</div><div class="hero-stat-label">Years Experience</div></div>
                </div>
            </div>
        </div>
    </div>
    <!-- Slide 2 -->
    <div class="hero-slide slide-2">
        <div class="hero-icon-bg"><i class="fas fa-tint"></i></div>
        <div class="container">
            <div class="hero-content">
                <span class="hero-tag">🔬 Scientifically Prepared</span>
                <h1 class="hero-title">Complete Range of<br><span>Mother Tinctures & Dilutions</span></h1>
                <p class="hero-desc">From Arnica to Calendula — explore our full catalog of classical homeopathic preparations for every ailment.</p>
                <div class="hero-actions">
                    <a href="@Url.Action("Index","Shop",new{categoryId=2})" class="btn-hero-primary">Mother Tinctures</a>
                    <a href="@Url.Action("Index","Shop",new{categoryId=1})" class="btn-hero-outline">View Dilutions</a>
                </div>
            </div>
        </div>
    </div>
    <!-- Slide 3 -->
    <div class="hero-slide slide-3">
        <div class="hero-icon-bg"><i class="fas fa-shipping-fast"></i></div>
        <div class="container">
            <div class="hero-content">
                <span class="hero-tag">🚚 Fast Delivery</span>
                <h1 class="hero-title">Free Delivery<br><span>On Orders Above ₹500</span></h1>
                <p class="hero-desc">Get your medicines delivered to your doorstep across India within 3–5 business days. Pan-India shipping available.</p>
                <div class="hero-actions">
                    <a href="@Url.Action("Index","Shop")" class="btn-hero-primary">Order Now</a>
                    <a href="@Url.Action("Contact","Home")" class="btn-hero-outline">Contact Us</a>
                </div>
            </div>
        </div>
    </div>
    <!-- Controls -->
    <button class="carousel-btn carousel-prev" onclick="prevSlide()"><i class="fas fa-chevron-left"></i></button>
    <button class="carousel-btn carousel-next" onclick="nextSlide()"><i class="fas fa-chevron-right"></i></button>
    <div class="carousel-dots">
        <button class="dot active" onclick="goSlide(0)"></button>
        <button class="dot" onclick="goSlide(1)"></button>
        <button class="dot" onclick="goSlide(2)"></button>
    </div>
</section>

<!-- ═══ TRUST BAR ════════════════════════════════════════════════════ -->
<section class="trust-bar">
    <div class="container">
        <div class="row gy-2">
            <div class="col-6 col-md-3"><div class="trust-item"><i class="fas fa-truck"></i> Free Delivery Above ₹500</div></div>
            <div class="col-6 col-md-3"><div class="trust-item"><i class="fas fa-shield-alt"></i> 100% Authentic Products</div></div>
            <div class="col-6 col-md-3"><div class="trust-item"><i class="fas fa-undo-alt"></i> Easy Returns & Refunds</div></div>
            <div class="col-6 col-md-3"><div class="trust-item"><i class="fas fa-headset"></i> 24×7 Customer Support</div></div>
        </div>
    </div>
</section>

<!-- ═══ CATEGORIES ════════════════════════════════════════════════════ -->
<section class="py-section bg-light-green">
    <div class="container">
        <div class="section-header">
            <div>
                <h2 class="section-title">Shop by Category</h2>
                <p class="section-subtitle">Explore our complete range of homeopathic products</p>
            </div>
            <a href="@Url.Action("Index","Shop")" class="view-all-btn">View All</a>
        </div>
        <div class="row g-3">
            @foreach (var cat in categories)
            {
                <div class="col-6 col-sm-4 col-md-3 col-lg-3">
                    <a href="@Url.Action("Index","Shop",new{categoryId=cat.Id})" class="cat-card">
                        <div class="cat-icon-circle" style="background:@cat.Color;">
                            <i class="@cat.Icon"></i>
                        </div>
                        <div class="cat-name">@cat.Name</div>
                        <div class="cat-count">@ProductCatalog.GetByCategory(cat.Id).Count products</div>
                    </a>
                </div>
            }
        </div>
    </div>
</section>

<!-- ═══ FEATURED PRODUCTS ═════════════════════════════════════════════ -->
<section class="py-section">
    <div class="container">
        <div class="section-header">
            <div>
                <h2 class="section-title">Featured Products</h2>
                <p class="section-subtitle">Handpicked top-quality homeopathic remedies</p>
            </div>
            <a href="@Url.Action("Index","Shop")" class="view-all-btn">View All</a>
        </div>
        <div class="row g-3">
            @foreach (var p in featured)
            {
                <div class="col-6 col-md-4 col-lg-3">
                    @Html.Partial("_ProductCard", p)
                </div>
            }
        </div>
    </div>
</section>

<!-- ═══ PROMO BANNER ══════════════════════════════════════════════════ -->
<section class="py-section-sm bg-light-green">
    <div class="container">
        <div class="promo-banner">
            <span class="promo-tag">LIMITED TIME OFFER</span>
            <h2 class="promo-title">Get 15% Off on Your First Order!</h2>
            <p class="promo-desc">Use code below at checkout. Valid on all products. Minimum purchase ₹299.</p>
            <div class="promo-code">HVIP15</div><br>
            <a href="@Url.Action("Index","Shop")" class="btn-promo"><i class="fas fa-shopping-bag me-2"></i>Shop Now & Save</a>
        </div>
    </div>
</section>

<!-- ═══ BESTSELLERS ═══════════════════════════════════════════════════ -->
<section class="py-section">
