@model HVIP.Models.ShopViewModel
@{
    ViewBag.Title = "Shop";
}

<!-- Breadcrumb -->
<div class="breadcrumb-bar">
    <div class="container">
        <span class="breadcrumb-list">
            <a href="@Url.Action("Index","Home")"><i class="fas fa-home"></i> Home</a>
            <span class="sep">/</span>
            <span>Shop</span>
            @if (Model.SelectedCategoryId.HasValue)
            {
                var cat = Model.Categories.Find(c => c.Id == Model.SelectedCategoryId.Value);
                if (cat != null)
                {
                    <span class="sep">/</span>
                    <span>@cat.Name</span>
                }
            }
        </span>
    </div>
</div>

<section class="py-section">
    <div class="container">
        <div class="row g-4">

            <!-- SIDEBAR -->
            <div class="col-lg-3">
                <div class="shop-sidebar">
                    <!-- Search -->
                    <div class="sidebar-section">
                        <div class="sidebar-title"><i class="fas fa-search me-2"></i>Search</div>
                        <form action="@Url.Action("Index","Shop")" method="get">
                            <div class="input-group">
                                <input type="text" name="q" class="form-control" placeholder="Search products..." value="@Model.SearchQuery" />
                                <button class="btn" style="background:var(--primary);color:#fff;" type="submit"><i class="fas fa-search"></i></button>
                            </div>
                        </form>
                    </div>

                    <!-- Categories -->
                    <div class="sidebar-section">
                        <div class="sidebar-title"><i class="fas fa-list me-2"></i>Categories</div>
                        <a href="@Url.Action("Index","Shop")" class="cat-filter @(Model.SelectedCategoryId == null ? "active" : "")">
                            <span>All Products</span>
                            <span class="badge" style="background:#e8f5e9;color:#1a6e2e;font-size:11px;">@Model.Categories.Count()</span>
                        </a>
                        @foreach (var cat in Model.Categories)
                        {
                            <a href="@Url.Action("Index","Shop",new{categoryId=cat.Id})" class="cat-filter @(Model.SelectedCategoryId==cat.Id?"active":"")">
                                <span><i class="@cat.Icon me-2" style="color:@cat.Color;width:18px;"></i>@cat.Name</span>
                            </a>
                        }
                    </div>

                    <!-- Price Filter -->
                    <div class="sidebar-section">
                        <div class="sidebar-title"><i class="fas fa-rupee-sign me-2"></i>Price Range</div>
                        <form action="@Url.Action("Index","Shop")" method="get">
                            @if (Model.SelectedCategoryId.HasValue)
                            { <input type="hidden" name="categoryId" value="@Model.SelectedCategoryId" /> }
                            @if (!string.IsNullOrEmpty(Model.SearchQuery))
                            { <input type="hidden" name="q" value="@Model.SearchQuery" /> }
                            <div class="d-flex gap-2 mb-2">
                                <input type="number" name="minPrice" class="form-control form-control-sm" placeholder="Min &#8377;" value="@Model.MinPrice" />
                                <input type="number" name="maxPrice" class="form-control form-control-sm" placeholder="Max &#8377;" value="@Model.MaxPrice" />
                            </div>
                            <button class="btn btn-sm w-100" style="background:var(--primary);color:#fff;">Apply Filter</button>
                        </form>
                        @if (Model.MinPrice.HasValue || Model.MaxPrice.HasValue)
                        {
                            <a href="@Url.Action("Index","Shop",new{categoryId=Model.SelectedCategoryId,q=Model.SearchQuery})" class="btn btn-sm btn-outline-secondary w-100 mt-1">Clear</a>
                        }
                    </div>

                    <!-- Quick Links -->
                    <div class="sidebar-section">
                        <div class="sidebar-title"><i class="fas fa-fire me-2" style="color:#f44336;"></i>Quick Access</div>
                        <a href="@Url.Action("Index","Shop",new{sort="rating"})" class="cat-filter"><i class="fas fa-star me-2" style="color:#ffc107;"></i>Top Rated</a>
                        <a href="@Url.Action("Index","Shop",new{sort="price_asc"})" class="cat-filter"><i class="fas fa-sort-amount-up me-2"></i>Price: Low to High</a>
                    </div>
                </div>
            </div>

            <!-- PRODUCTS GRID -->
            <div class="col-lg-9">
                <!-- Shop Header -->
                <div class="shop-header">
                    <div class="results-count">
                        Showing <strong>@Model.TotalProducts</strong> products
                        @if (!string.IsNullOrEmpty(Model.SearchQuery)) { <span>for "<strong>@Model.SearchQuery</strong>"</span> }
                        @if (Model.SelectedCategoryId.HasValue)
                        {
                            var cat = Model.Categories.Find(c => c.Id == Model.SelectedCategoryId.Value);
                            if (cat != null) { <span>in <strong>@cat.Name</strong></span> }
                        }
                    </div>
                    <form action="@Url.Action("Index","Shop")" method="get" class="d-flex align-items-center gap-2">
                        @if (Model.SelectedCategoryId.HasValue) { <input type="hidden" name="categoryId" value="@Model.SelectedCategoryId" /> }
                        @if (!string.IsNullOrEmpty(Model.SearchQuery)) { <input type="hidden" name="q" value="@Model.SearchQuery" /> }
                        <label style="font-size:13.5px;color:var(--text-muted);white-space:nowrap;">Sort by:</label>
                        <select name="sort" class="sort-sel" onchange="this.form.submit()">
                            <option value="featured"   @(Model.SortBy=="featured"  ?"selected":"")>Featured</option>
                            <option value="rating"     @(Model.SortBy=="rating"    ?"selected":"")>Top Rated</option>
                            <option value="price_asc"  @(Model.SortBy=="price_asc" ?"selected":"")>Price: Low → High</option>
                            <option value="price_desc" @(Model.SortBy=="price_desc"?"selected":"")>Price: High → Low</option>
                            <option value="name"       @(Model.SortBy=="name"      ?"selected":"")>Name A–Z</option>
                        </select>
                    </form>
                </div>

                @if (!Model.Products.Any())
                {
                    <div class="text-center py-5">
                        <i class="fas fa-search-minus" style="font-size:60px;color:#c8e6c9;"></i>
                        <h4 class="mt-3">No products found</h4>
                        <p class="text-muted">Try adjusting your search or filters.</p>
                        <a href="@Url.Action("Index","Shop")" class="btn-continue">Browse All Products</a>
                    </div>
                }
                else
                {
                    <div class="row g-3">
                        @foreach (var p in Model.Products)
                        {
                            <div class="col-6 col-md-4">
                                @Html.Partial("_ProductCard", p)
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
</section>
