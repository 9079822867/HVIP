@model HVIP.Models.Product
@using HVIP.Models
@{
    ViewBag.Title = Model.Name;
    var related = ViewBag.RelatedProducts as List<Product> ?? new List<Product>();
    int discount = Model.DiscountPercent;
}

<!-- Breadcrumb -->
<div class="breadcrumb-bar">
    <div class="container">
        <span class="breadcrumb-list">
            <a href="@Url.Action("Index","Home")"><i class="fas fa-home"></i> Home</a>
            <span class="sep">/</span>
            <a href="@Url.Action("Index","Shop")">Shop</a>
            <span class="sep">/</span>
            <a href="@Url.Action("Index","Shop",new{categoryId=Model.CategoryId})">@Model.CategoryName</a>
            <span class="sep">/</span>
            <span>@Model.Name</span>
        </span>
    </div>
</div>

<section class="py-section">
    <div class="container">
        <div class="row g-4">

            <!-- Product Image / Icon -->
            <div class="col-lg-5">
                <div class="detail-icon-area" style="background:linear-gradient(135deg,@Model.CategoryColor 0%,@(Model.CategoryColor)bb 100%);">
                    <i class="@Model.CategoryIcon"></i>
                </div>
                <!-- Badges -->
                <div class="d-flex gap-2 flex-wrap mt-2">
                    @if (Model.IsOnSale) { <span class="badge-pill badge-sale">-@discount% OFF</span> }
                    @if (Model.IsNew)    { <span class="badge-pill badge-new">NEW ARRIVAL</span> }
                    @if (Model.IsBestseller) { <span class="badge-pill badge-best">BESTSELLER</span> }
                    @if (Model.Stock > 0) { <span class="badge-pill" style="background:#e8f5e9;color:#1a6e2e;">In Stock (@Model.Stock units)</span> }
                </div>
            </div>

            <!-- Product Info -->
            <div class="col-lg-7">
                <div class="detail-cat-badge">
                    <i class="@Model.CategoryIcon"></i> @Model.CategoryName
                </div>
                <h1 class="detail-title">@Model.Name</h1>

                <!-- Rating -->
                <div class="d-flex align-items-center gap-2 mb-3">
                    <div style="color:#ffc107;font-size:15px;">
                        @for (int i = 1; i <= 5; i++)
                        {
                            if (i <= Math.Floor(Model.Rating))     { <i class="fas fa-star"></i> }
                            else if (i - 0.5 <= Model.Rating)      { <i class="fas fa-star-half-alt"></i> }
                            else                                    { <i class="far fa-star"></i> }
                        }
                    </div>
                    <span style="font-size:14px;color:var(--text-muted);">@Model.Rating.ToString("0.0") (@Model.ReviewCount reviews)</span>
                </div>

                <!-- Price -->
                <div class="detail-price-block">
                    <span class="detail-price">@Model.Price.ToString("0")</span>
                    @if (Model.IsOnSale)
                    {
                        <span class="detail-orig">@Model.OriginalPrice.Value.ToString("0")</span>
                        <span class="detail-disc">@discount% OFF</span>
                    }
                    <span style="font-size:13px;color:var(--text-muted);">Incl. of all taxes</span>
                </div>

                <!-- Size -->
                <p><strong>Pack Size:</strong> <span class="badge" style="background:#e8f5e9;color:#1a6e2e;padding:5px 12px;border-radius:20px;">@Model.Size</span></p>

                <!-- Short Desc -->
                <p style="font-size:15px;color:var(--text-dark);"><i class="fas fa-check-circle text-success me-1"></i>@Model.ShortDescription</p>

                <!-- Quantity -->
                <div class="mt-3 mb-3">
                    <label style="font-size:14px;font-weight:600;display:block;margin-bottom:8px;">Quantity:</label>
                    <div class="qty-selector">
                        <button class="qty-btn" onclick="changeQty(-1)"><i class="fas fa-minus"></i></button>
                        <input type="number" id="qtyInput" class="qty-input" value="1" min="1" max="99" />
                        <button class="qty-btn" onclick="changeQty(1)"><i class="fas fa-plus"></i></button>
                    </div>
                </div>

                <!-- Actions -->
                <div class="d-flex gap-3 flex-wrap">
                    <button class="btn-cart-lg" onclick="addToCartWithQty(@Model.Id)">
                        <i class="fas fa-shopping-cart"></i> Add to Cart
                    </button>
                    <a href="@Url.Action("Index","Cart")" class="btn-cart-lg" style="background:var(--accent);" onclick="addToCartWithQty(@Model.Id); return true;">
                        <i class="fas fa-bolt"></i> Buy Now
                    </a>
                </div>

                <!-- Delivery Info -->
                <div class="mt-3 p-3 rounded" style="background:#f8fdf8;border:1px solid #c8e6c9;font-size:13.5px;">
                    <div><i class="fas fa-truck text-success me-2"></i>Free delivery on orders above &#8377;500</div>
                    <div class="mt-1"><i class="fas fa-undo-alt text-success me-2"></i>Easy returns within 7 days</div>
                    <div class="mt-1"><i class="fas fa-shield-alt text-success me-2"></i>100% authentic product guaranteed</div>
                </div>
            </div>
        </div>

        <!-- Description -->
        <div class="row mt-4">
            <div class="col-12">
                <div style="border-top:2px solid var(--primary-xlight);padding-top:24px;">
                    <h4 style="color:var(--primary-dark);margin-bottom:16px;"><i class="fas fa-info-circle me-2"></i>Product Description</h4>
                    <p style="font-size:15px;line-height:1.8;color:#444;">@Model.Description</p>

                    <div class="row mt-4 g-3">
                        <div class="col-md-6">
                            <table class="table table-bordered" style="font-size:14px;">
                                <tr><th style="background:#e8f5e9;width:40%;">Brand</th><td>@Model.Brand</td></tr>
                                <tr><th style="background:#e8f5e9;">Category</th><td>@Model.CategoryName</td></tr>
                                <tr><th style="background:#e8f5e9;">Pack Size</th><td>@Model.Size</td></tr>
                                <tr><th style="background:#e8f5e9;">Stock</th><td>@(Model.Stock > 0 ? "In Stock" : "Out of Stock")</td></tr>
                            </table>
                        </div>
                        <div class="col-md-6">
                            <div style="background:#e8f5e9;border-radius:12px;padding:20px;">
                                <h6 style="color:var(--primary-dark);"><i class="fas fa-exclamation-circle me-2"></i>Disclaimer</h6>
                                <p style="font-size:12.5px;color:#555;margin-bottom:0;">
                                    Homeopathic products are not intended to diagnose, treat, cure or prevent any disease.
                                    Consult a qualified homeopathic physician before use. Keep out of reach of children.
                                    Store in a cool, dry place away from direct sunlight.
                                </p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Related Products -->
        @if (related.Any())
        {
            <div class="mt-5">
                <h3 style="color:var(--primary-dark);margin-bottom:20px;"><i class="fas fa-th me-2"></i>Related Products</h3>
                <div class="row g-3">
                    @foreach (var p in related)
                    {
                        <div class="col-6 col-md-3">
                            @Html.Partial("_ProductCard", p)
                        </div>
                    }
                </div>
            </div>
        }
    </div>
</section>

@section scripts {
<script>
    function addToCartWithQty(id) {
        var qty = parseInt(document.getElementById('qtyInput').value) || 1;
        addToCart(id, qty);
    }
</script>
}
