@model List<HVIP.Models.ContactMessage>
@{ Layout = "~/Views/Admin/_AdminLayout.cshtml"; ViewBag.Title = "Contact Messages"; ViewBag.AdminPage = "messages"; }

<div class="admin-card">
    <div class="admin-card-header"><i class="fas fa-envelope me-2"></i>Contact Messages (@Model.Count)</div>
    <div class="table-responsive">
        <table class="admin-table">
            <thead><tr><th>Name</th><th>Email</th><th>Phone</th><th>Subject</th><th>Message</th></tr></thead>
            <tbody>
                @if (Model.Count == 0)
                {
                    <tr><td colspan="5" class="text-center text-muted py-5"><i class="fas fa-inbox fa-2x d-block mb-2"></i>No messages yet</td></tr>
                }
                @foreach (var m in Model)
                {
                    <tr>
                        <td><strong>@m.Name</strong></td>
                        <td><a href="mailto:@m.Email">@m.Email</a></td>
                        <td>@m.Phone</td>
                        <td><span style="font-size:12px;background:#e8f5e9;padding:3px 8px;border-radius:20px;">@m.Subject</span></td>
                        <td style="max-width:300px;font-size:13px;">@m.Message</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
