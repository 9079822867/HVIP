@model List<HVIP.Models.OrderSummary>
@{ Layout = "~/Views/Admin/_AdminLayout.cshtml"; ViewBag.Title = "Orders"; ViewBag.AdminPage = "orders"; }

<div class="admin-card">
    <div class="admin-card-header"><i class="fas fa-shopping-bag me-2"></i>All Orders (@Model.Count)</div>
    <div class="table-responsive">
        <table class="admin-table">
            <thead>
                <tr><th>Order #</th><th>Customer</th><th>Items</th><th>Amount</th><th>Payment</th><th>Status</th><th>Date</th><th>Update</th></tr>
            </thead>
            <tbody>
                @if (Model.Count == 0)
                {
                    <tr><td colspan="8" class="text-center text-muted py-5"><i class="fas fa-box-open fa-2x d-block mb-2"></i>No orders yet</td></tr>
                }
                @foreach (var o in Model)
                {
                    <tr>
                        <td><strong>#@o.OrderNumber</strong></td>
                        <td>@o.CustomerName<br><small class="text-muted">@o.Email</small></td>
                        <td><span class="admin-badge">@o.ItemCount items</span></td>
                        <td><strong>₹@o.GrandTotal.ToString("N0")</strong></td>
                        <td>@o.PaymentMethod</td>
                        <td><span class="admin-status-badge @(o.Status=="Confirmed"?"badge-confirmed":o.Status=="Shipped"?"badge-shipped":"badge-pending")">@o.Status</span></td>
                        <td>@o.OrderDate.ToString("dd MMM yy, hh:mm tt")</td>
                        <td>
                            @using (Html.BeginForm("OrderStatus","Admin",FormMethod.Post,new{@class="d-flex gap-1"}))
                            {
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@o.Id" />
                                <select name="status" class="admin-input" style="padding:5px 8px;font-size:12px;width:120px;">
                                    @foreach (var s in new[]{"Confirmed","Processing","Shipped","Delivered","Cancelled"})
                                    {<option value="@s" @(o.Status==s?"selected":"")>@s</option>}
                                </select>
                                <button type="submit" class="admin-action-btn edit" title="Update"><i class="fas fa-check"></i></button>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
