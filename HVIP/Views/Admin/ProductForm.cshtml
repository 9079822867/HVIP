@model HVIP.Models.ProductFormViewModel
@{ Layout = "~/Views/Admin/_AdminLayout.cshtml"; ViewBag.AdminPage = "products"; }

<div class="admin-card" style="max-width:860px;">
    <div class="admin-card-header">
        <i class="fas fa-@(Model.IsEdit?"edit":"plus") me-2"></i>@ViewBag.Title
    </div>
    <div class="p-4">
        @using (Html.BeginForm("ProductEdit", "Admin", FormMethod.Post))
        {
            @Html.AntiForgeryToken()
            @Html.HiddenFor(m => m.Id)

            <div class="row g-3">
                <div class="col-12">
                    <label class="admin-label">Product Name *</label>
                    @Html.TextBoxFor(m => m.Name, new { @class = "admin-input", placeholder = "e.g. Arnica Montana 30C" })
                    @Html.ValidationMessageFor(m => m.Name, "", new { @class = "admin-field-error" })
                </div>
                <div class="col-md-6">
                    <label class="admin-label">Short Description</label>
                    @Html.TextBoxFor(m => m.ShortDescription, new { @class = "admin-input", placeholder = "One-line summary" })
                </div>
                <div class="col-md-6">
                    <label class="admin-label">Category *</label>
                    @Html.DropDownListFor(m => m.CategoryId, Model.CategoryOptions, "-- Select Category --", new { @class = "admin-input" })
                    @Html.ValidationMessageFor(m => m.CategoryId, "", new { @class = "admin-field-error" })
                </div>
                <div class="col-12">
                    <label class="admin-label">Full Description</label>
                    @Html.TextAreaFor(m => m.Description, new { @class = "admin-input", rows = "4" })
                </div>
                <div class="col-md-3">
                    <label class="admin-label">Price (&#8377;) *</label>
                    @Html.TextBoxFor(m => m.Price, new { @class = "admin-input", type = "number", step = "0.01" })
                    @Html.ValidationMessageFor(m => m.Price, "", new { @class = "admin-field-error" })
                </div>
                <div class="col-md-3">
                    <label class="admin-label">Original Price (&#8377;)</label>
                    @Html.TextBoxFor(m => m.OriginalPrice, new { @class = "admin-input", type = "number", step = "0.01", placeholder = "Leave blank if no discount" })
                </div>
                <div class="col-md-3">
                    <label class="admin-label">Stock</label>
                    @Html.TextBoxFor(m => m.Stock, new { @class = "admin-input", type = "number" })
                </div>
                <div class="col-md-3">
                    <label class="admin-label">Size</label>
                    @Html.TextBoxFor(m => m.Size, new { @class = "admin-input", placeholder = "e.g. 30ml, 25g" })
                </div>
                <div class="col-md-4">
                    <label class="admin-label">Brand</label>
                    @Html.TextBoxFor(m => m.Brand, new { @class = "admin-input" })
                </div>
                <div class="col-md-4">
                    <label class="admin-label">Rating (0–5)</label>
                    @Html.TextBoxFor(m => m.Rating, new { @class = "admin-input", type = "number", step = "0.1", min = "0", max = "5" })
                </div>
                <div class="col-md-4">
                    <label class="admin-label">Review Count</label>
                    @Html.TextBoxFor(m => m.ReviewCount, new { @class = "admin-input", type = "number" })
                </div>

                <!-- Flags -->
                <div class="col-12">
                    <div class="d-flex flex-wrap gap-4 mt-2">
                        <label class="admin-checkbox"><input type="checkbox" name="IsFeatured"   value="true" @(Model.IsFeatured  ?"checked":"")/> Featured</label>
                        <label class="admin-checkbox"><input type="checkbox" name="IsBestseller" value="true" @(Model.IsBestseller?"checked":"")/> Bestseller</label>
                        <label class="admin-checkbox"><input type="checkbox" name="IsNew"        value="true" @(Model.IsNew       ?"checked":"")/> New Arrival</label>
                        <label class="admin-checkbox"><input type="checkbox" name="IsActive"     value="true" @(Model.IsActive    ?"checked":"")/> Active (visible)</label>
                    </div>
                </div>

                <div class="col-12 d-flex gap-3 mt-2">
                    <button type="submit" class="admin-btn-primary"><i class="fas fa-save me-1"></i>@(Model.IsEdit?"Save Changes":"Add Product")</button>
                    <a href="@Url.Action("Products","Admin")" class="admin-btn-secondary">Cancel</a>
                </div>
            </div>
        }
    </div>
</div>
