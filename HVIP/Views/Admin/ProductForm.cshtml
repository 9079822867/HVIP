@model HVIP.Models.ProductFormViewModel
@{ Layout = "~/Views/Admin/_AdminLayout.cshtml"; ViewBag.AdminPage = "products"; }
@section scripts {
<script>
function previewProductImg(input) {
    var preview = document.getElementById('imgPreview');
    var placeholder = document.getElementById('imgPlaceholder');
    if (input.files && input.files[0]) {
        var reader = new FileReader();
        reader.onload = function(e) {
            preview.src = e.target.result;
            preview.style.display = 'block';
            if (placeholder) placeholder.style.display = 'none';
        };
        reader.readAsDataURL(input.files[0]);
    }
}
</script>
}

<div class="admin-card" style="max-width:860px;">
    <div class="admin-card-header">
        <i class="fas fa-@(Model.IsEdit?"edit":"plus") me-2"></i>@ViewBag.Title
    </div>
    <div class="p-4">
        @using (Html.BeginForm("ProductEdit", "Admin", FormMethod.Post, new { enctype = "multipart/form-data" }))
        {
            @Html.AntiForgeryToken()
            @Html.HiddenFor(m => m.Id)
            @Html.HiddenFor(m => m.ImageUrl)

            <div class="row g-3">
                <div class="col-12">
                    <label class="admin-label">Product Name *</label>
                    @Html.TextBoxFor(m => m.Name, new { @class = "admin-input", placeholder = "e.g. Arnica Montana 30C" })
                    @Html.ValidationMessageFor(m => m.Name, "", new { @class = "admin-field-error" })
                </div>
                <div class="col-md-6">
                    <label class="admin-label">Short Description</label>
                    @Html.TextBoxFor(m => m.ShortDescription, new { @class = "admin-input", placeholder = "One-line summary" })
                </div>
                <div class="col-md-6">
                    <label class="admin-label">Category *</label>
                    @Html.DropDownListFor(m => m.CategoryId, Model.CategoryOptions, "-- Select Category --", new { @class = "admin-input" })
                    @Html.ValidationMessageFor(m => m.CategoryId, "", new { @class = "admin-field-error" })
                </div>
                <div class="col-12">
                    <label class="admin-label">Full Description</label>
                    @Html.TextAreaFor(m => m.Description, new { @class = "admin-input", rows = "4" })
                </div>
                <div class="col-md-3">
                    <label class="admin-label">Price (&#8377;) *</label>
                    @Html.TextBoxFor(m => m.Price, new { @class = "admin-input", type = "number", step = "0.01" })
                    @Html.ValidationMessageFor(m => m.Price, "", new { @class = "admin-field-error" })
                </div>
                <div class="col-md-3">
                    <label class="admin-label">Original Price (&#8377;)</label>
                    @Html.TextBoxFor(m => m.OriginalPrice, new { @class = "admin-input", type = "number", step = "0.01", placeholder = "Leave blank if no discount" })
                </div>
                <div class="col-md-3">
                    <label class="admin-label">Stock</label>
                    @Html.TextBoxFor(m => m.Stock, new { @class = "admin-input", type = "number" })
                </div>
                <div class="col-md-3">
                    <label class="admin-label">Size</label>
                    @Html.TextBoxFor(m => m.Size, new { @class = "admin-input", placeholder = "e.g. 30ml, 25g" })
                </div>
                <div class="col-md-4">
                    <label class="admin-label">Brand</label>
                    @Html.TextBoxFor(m => m.Brand, new { @class = "admin-input" })
                </div>
                <div class="col-md-4">
                    <label class="admin-label">Rating (0–5)</label>
                    @Html.TextBoxFor(m => m.Rating, new { @class = "admin-input", type = "number", step = "0.1", min = "0", max = "5" })
                </div>
                <div class="col-md-4">
                    <label class="admin-label">Review Count</label>
                    @Html.TextBoxFor(m => m.ReviewCount, new { @class = "admin-input", type = "number" })
                </div>

                <!-- Image Upload -->
                <div class="col-12">
                    <label class="admin-label"><i class="fas fa-image me-1"></i>Product Image</label>
                    <div class="d-flex align-items-start gap-3 flex-wrap">

                        @* Current image preview *@
                        <div id="imgPreviewWrap" style="width:120px;height:100px;border-radius:8px;overflow:hidden;border:2px dashed #ccc;display:flex;align-items:center;justify-content:center;background:#f9f9f9;flex-shrink:0;">
                            @if (!string.IsNullOrEmpty(Model.ImageUrl))
                            {
                                <img id="imgPreview" src="@Model.ImageUrl" style="width:100%;height:100%;object-fit:cover;" />
                            }
                            else
                            {
                                <i id="imgPlaceholder" class="fas fa-image" style="font-size:36px;color:#ccc;"></i>
                                <img id="imgPreview" src="" style="width:100%;height:100%;object-fit:cover;display:none;" />
                            }
                        </div>

                        <div>
                            <input type="file" name="ImageFile" id="ImageFile" accept=".jpg,.jpeg,.png,.gif,.webp"
                                   class="admin-input" style="max-width:280px;"
                                   onchange="previewProductImg(this)" />
                            <small class="text-muted d-block mt-1">JPG, PNG, GIF, WEBP — max 5 MB</small>
                            @if (!string.IsNullOrEmpty(Model.ImageUrl))
                            {
                                <label class="admin-checkbox mt-2">
                                    @Html.CheckBoxFor(m => m.RemoveImage)
                                    <span class="text-danger"><i class="fas fa-trash me-1"></i>Remove current image</span>
                                </label>
                            }
                        </div>
                    </div>
                </div>

                <!-- Flags -->
                <div class="col-12">
                    <div class="d-flex flex-wrap gap-4 mt-2">
                        <label class="admin-checkbox">@Html.CheckBoxFor(m => m.IsFeatured)   Featured</label>
                        <label class="admin-checkbox">@Html.CheckBoxFor(m => m.IsBestseller) Bestseller</label>
                        <label class="admin-checkbox">@Html.CheckBoxFor(m => m.IsNew)        New Arrival</label>
                        <label class="admin-checkbox">@Html.CheckBoxFor(m => m.IsActive)     Active (visible)</label>
                    </div>
                </div>

                <div class="col-12 d-flex gap-3 mt-2">
                    <button type="submit" class="admin-btn-primary"><i class="fas fa-save me-1"></i>@(Model.IsEdit?"Save Changes":"Add Product")</button>
                    <a href="@Url.Action("Products","Admin")" class="admin-btn-secondary">Cancel</a>
                </div>
            </div>
        }
    </div>
</div>
