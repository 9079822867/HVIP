@model HVIP.Models.ShippingSettings
@{ Layout = "~/Views/Admin/_AdminLayout.cshtml"; ViewBag.Title = "Shipping Settings"; ViewBag.AdminPage = "shipping"; }

<div class="row g-3">
    <div class="col-lg-6">
        <div class="admin-card">
            <div class="admin-card-header"><i class="fas fa-truck me-2"></i>Shipping Configuration</div>
            <div class="p-4">
                @using (Html.BeginForm("ShippingSettings","Admin",FormMethod.Post))
                {
                    @Html.AntiForgeryToken()

                    if (!ViewData.ModelState.IsValid)
                    {
                        <div class="alert alert-danger mb-3" style="font-size:13.5px;border-radius:8px;">
                            @Html.ValidationSummary(true)
                        </div>
                    }

                    <div class="mb-4">
                        <label class="admin-label">
                            <i class="fas fa-tag me-1" style="color:var(--primary);"></i>
                            Free Shipping Threshold (&#8377;)
                        </label>
                        @Html.TextBoxFor(m => m.FreeThreshold, new { @class="admin-input", type="number", min="0", step="10", placeholder="e.g. 500" })
                        <div class="mt-1" style="font-size:12px;color:var(--text-muted);">Orders at or above this amount get free shipping.</div>
                    </div>

                    <div class="mb-4">
                        <label class="admin-label">
                            <i class="fas fa-rupee-sign me-1" style="color:var(--primary);"></i>
                            Shipping Charge (&#8377;)
                        </label>
                        @Html.TextBoxFor(m => m.Charge, new { @class="admin-input", type="number", min="0", step="5", placeholder="e.g. 60" })
                        <div class="mt-1" style="font-size:12px;color:var(--text-muted);">Applied when order total is below the threshold.</div>
                    </div>

                    <button type="submit" class="admin-save-btn"><i class="fas fa-save me-1"></i>Save Settings</button>
                }
            </div>
        </div>
    </div>

    <div class="col-lg-6">
        <div class="admin-card">
            <div class="admin-card-header"><i class="fas fa-info-circle me-2"></i>How It Works</div>
            <div class="p-4">
                <div id="preview-box" style="background:#f8fdf8;border:2px solid #c8e6c9;border-radius:12px;padding:20px;">
                    <h6 style="color:var(--primary-dark);margin-bottom:16px;"><i class="fas fa-calculator me-2"></i>Current Rule Preview</h6>

                    <div class="d-flex justify-content-between align-items-center p-2 mb-2 rounded" style="background:#fff;border:1px solid #e0e0e0;">
                        <span style="font-size:14px;"><i class="fas fa-times-circle text-danger me-2"></i>Order below <strong id="preview-threshold">&#8377;@Model.FreeThreshold.ToString("0")</strong></span>
                        <span class="badge-pill" style="background:#ffebee;color:#c62828;font-size:12px;padding:4px 10px;border-radius:20px;">+&#8377;<span id="preview-charge">@Model.Charge.ToString("0")</span> shipping</span>
                    </div>

                    <div class="d-flex justify-content-between align-items-center p-2 rounded" style="background:#fff;border:1px solid #e0e0e0;">
                        <span style="font-size:14px;"><i class="fas fa-check-circle text-success me-2"></i>Order &#8377;<span id="preview-threshold2">@Model.FreeThreshold.ToString("0")</span> or above</span>
                        <span class="badge-pill" style="background:#e8f5e9;color:#1a6e2e;font-size:12px;padding:4px 10px;border-radius:20px;">FREE shipping</span>
                    </div>
                </div>

                <div class="mt-3" style="font-size:13px;color:#555;line-height:1.7;">
                    <i class="fas fa-lightbulb text-warning me-1"></i>
                    <strong>Tip:</strong> Set Free Threshold to <strong>0</strong> for always-free shipping.
                    Set Shipping Charge to <strong>0</strong> for free shipping on all orders regardless of threshold.
                </div>
            </div>
        </div>

        <div class="admin-card mt-3">
            <div class="admin-card-header"><i class="fas fa-chart-bar me-2"></i>Applied To</div>
            <div class="p-4" style="font-size:13.5px;color:#444;line-height:2;">
                <div><i class="fas fa-shopping-cart text-success me-2"></i>Shopping Cart summary</div>
                <div><i class="fas fa-credit-card text-success me-2"></i>Checkout order total</div>
                <div><i class="fas fa-receipt text-success me-2"></i>Order confirmation</div>
                <div><i class="fas fa-truck text-success me-2"></i>"Free delivery" banner on product pages</div>
            </div>
        </div>
    </div>
</div>

@section scripts {
<script>
    // Live preview update
    document.getElementById('FreeThreshold').addEventListener('input', function () {
        var v = parseFloat(this.value) || 0;
        document.getElementById('preview-threshold').innerHTML = '&#8377;' + v.toFixed(0);
        document.getElementById('preview-threshold2').textContent = v.toFixed(0);
    });
    document.getElementById('Charge').addEventListener('input', function () {
        var v = parseFloat(this.value) || 0;
        document.getElementById('preview-charge').textContent = v.toFixed(0);
    });
</script>
}
